{
	"name": "ts-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --passWithNoTests",
		"check": "concurrently \"pnpm typecheck\" \"pnpm lint\" \"pnpm format:check\"",
		"clean": "rm -rf .next coverage *.tsbuildinfo",
		"script": "tsx --env-file-if-exists=.env",
		"typecheck": "next typegen && tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@ai-sdk/provider-utils": "^4.0.23",
		"@openrouter/ai-sdk-provider": "^2.8.0",
		"ai": "^6.0.168",
		"drizzle-orm": "^0.45.2",
		"next": "^16.2.4",
		"p-limit": "^7.3.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.4",
		"prettier": "^3.8.3",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	}
}
