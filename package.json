{
	"name": "ts-template",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --passWithNoTests",
		"check": "concurrently \"pnpm typecheck\" \"pnpm lint\"",
		"typecheck": "next typegen && tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@ai-sdk/provider-utils": "^4.0.23",
		"@openrouter/ai-sdk-provider": "^2.3.3",
		"ai": "^6.0.0",
		"drizzle-orm": "^0.44.0",
		"next": "^15.3.1",
		"p-limit": "^7.0.0",
		"pino": "^9.6.0",
		"pino-pretty": "^13.0.0",
		"postgres": "^3.4.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.1",
		"@tailwindcss/postcss": "^4.1.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"drizzle-kit": "^0.31.0",
		"concurrently": "^9.1.2",
		"eslint": "^9.0.0",
		"eslint-config-next": "^15.3.1",
		"prettier": "^3.5.0",
		"tailwindcss": "^4.1.0",
		"tsx": "^4.19.0",
		"typescript": "^5.8.0",
		"vitest": "^3.2.4"
	}
}
